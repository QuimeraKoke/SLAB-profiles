# Postgres
POSTGRES_DB=slab
POSTGRES_USER=slab
POSTGRES_PASSWORD=slab

# Django
DEBUG=true
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT (defaults to DJANGO_SECRET_KEY if unset)
JWT_SECRET=dev-jwt-secret-change-me
JWT_LIFETIME_HOURS=12

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# S3 / file storage
# Local dev (docker-compose): MinIO is wired below.
# Production (real AWS S3 / R2 / etc.): set the bucket + region + keys, and
# LEAVE BLANK or omit AWS_S3_ENDPOINT_URL / AWS_S3_PUBLIC_ENDPOINT_URL /
# AWS_S3_ADDRESSING_STYLE / AWS_S3_URL_PROTOCOL — settings.py coerces empty
# strings to None so boto3 picks the canonical AWS endpoint, virtual-host
# addressing, and HTTPS. See RAILWAY_DEPLOY.md.
AWS_STORAGE_BUCKET_NAME=slab-attachments
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_URL_PROTOCOL=http:
AWS_ACCESS_KEY_ID=slabminio
AWS_SECRET_ACCESS_KEY=slabminio-secret

# Email (alert notifications)
# Default backend prints emails to stdout — switch to SMTP / SES / SendGrid
# in production by setting EMAIL_BACKEND + the host/credentials below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=alerts@s-lab.cl

# Used to build "open in app" links inside alert emails.
FRONTEND_BASE_URL=http://localhost:3000
